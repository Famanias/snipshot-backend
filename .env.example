# ======================================
# SnipShot Backend Environment Variables
# ======================================
# Copy this file to .env and fill in values

# ---- Server Config ----
BACKEND_PORT=8001
DEBUG=false

# ---- Database ----
# For local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./snipshot.db

# For Render PostgreSQL (use this format):
# DATABASE_URL=postgres://user:password@host:port/database

# ---- JWT Authentication ----
# IMPORTANT: Generate a strong secret key for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Cloudinary (Image Storage) ----
# Sign up at: https://cloudinary.com/
# Find these in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- Groq (Translation) ----
GROQ_API_KEY=your-groq-api-key

#ENDPOINTS FOR LOCAL USE 
# PUT IN THE FRONTEND REPOS
# TRANSLATOR_URL=http://10.0.2.2:8001 #DESKTOP
# TRANSLATOR_URL=http://192.168.1.50:8001 #android

#http://192.168.100.22:8001
