# SnipShot Database API - Supabase Configuration
# Copy this to .env and fill in your values from Supabase Dashboard

# ===========================================
# SUPABASE SETTINGS (Required)
# ===========================================

# Project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (Settings > API > Project API keys > anon public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (Settings > API > Project API keys > service_role)
# Used for admin operations - KEEP SECRET!
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret (Settings > API > JWT Settings > JWT Secret)
# Used to verify access tokens
SUPABASE_JWT_SECRET=your-jwt-secret

# Storage bucket name (create in Storage section)
SUPABASE_STORAGE_BUCKET=images

# ===========================================
# DATABASE (Auto-configured by Supabase)
# ===========================================

# PostgreSQL connection string (Settings > Database > Connection string > URI)
# Use the "Transaction" pooler for serverless environments
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
